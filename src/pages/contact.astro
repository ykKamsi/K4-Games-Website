---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout title="Contact" description="Get in touch with K4 Games - reach out for collaborations, inquiries, or just to say hello.">
  <section class="contact-page">
    <div class="container">
      <div class="contact-hero animate-fade-in-up">
        <h1 class="page-title">Get In Touch</h1>
        <p class="page-subtitle">
          Have a question, want to collaborate, or just want to say hello? We'd love to hear from you.
        </p>
      </div>

      <div class="contact-grid">
        <div class="contact-form-wrapper glass animate-fade-in-up">
          <h2 class="form-heading">Send Us a Message</h2>
          <ContactForm />
        </div>

        <div class="contact-info animate-fade-in-up">
          <div class="info-card glass">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <h3>Roblox</h3>
            <p>Find us on the Roblox platform</p>
            <a href="https://www.roblox.com/users/161411522/profile" target="_blank" rel="noopener noreferrer" class="info-link">
              View Profile
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>

          <div class="info-card glass">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            </div>
            <h3>K4 Games Group</h3>
            <p>Join our main Roblox group</p>
            <a href="https://www.roblox.com/groups/427824840" target="_blank" rel="noopener noreferrer" class="info-link">
              Join Group
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>

          <div class="info-card glass">
            <div class="info-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3>K4 Quick Games</h3>
            <p>Our competitive games studio</p>
            <a href="https://www.roblox.com/groups/1034948068" target="_blank" rel="noopener noreferrer" class="info-link">
              Visit Group
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding-top: 8rem;
    padding-bottom: 4rem;
    min-height: 100vh;
  }

  .contact-hero {
    text-align: center;
    margin-bottom: 4rem;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    margin-bottom: 0.75rem;
    background: linear-gradient(135deg, var(--text-primary) 0%, var(--accent-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    max-width: 500px;
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 2rem;
    align-items: start;
  }

  .contact-form-wrapper {
    padding: 2.5rem;
  }

  .form-heading {
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: var(--text-primary);
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .info-card {
    padding: 1.5rem;
    transition: all var(--transition-normal);
  }

  .info-card:hover {
    border-color: var(--border-color-hover);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  .info-icon {
    color: var(--accent-light);
    margin-bottom: 0.75rem;
  }

  .info-card h3 {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .info-card p {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0.75rem;
  }

  .info-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--accent-light);
    transition: all var(--transition-fast);
  }

  .info-link:hover {
    color: var(--accent);
    gap: 0.5rem;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .contact-form-wrapper {
      padding: 1.5rem;
    }
  }
</style>
