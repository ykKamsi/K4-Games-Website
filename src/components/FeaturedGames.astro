---
import GameCard from './GameCard.astro';
import { featuredGames } from '../data/games';
---

<section class="featured-section section">
  <div class="container">
    <div class="section-header animate-fade-in-up">
      <h2 class="section-title">Featured Games</h2>
      <p class="section-subtitle">Our most popular Roblox experiences</p>
    </div>

    <div class="games-grid stagger">
      {featuredGames.map(game => (
        <GameCard
          name={game.name}
          placeId={game.placeId}
          visits={game.visits}
          favorites={game.favorites}
          group={game.group}
          thumbnailUrl={game.thumbnailUrl}
          description={game.description}
        />
      ))}
    </div>

    <div class="view-all animate-fade-in-up">
      <a href="/games" class="btn btn-secondary">
        View All Games
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .view-all {
    text-align: center;
  }

  @media (max-width: 640px) {
    .games-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
